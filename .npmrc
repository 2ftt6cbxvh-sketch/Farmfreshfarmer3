# Elastic Beanstalk runs `npm install` on deploy. The production bundle in
# dist/ is committed to the ZIP, so we never build on the server — but the
# runtime still needs the (non-dev) dependencies installed. Keep this default
# so EB installs them. Do NOT set production=true here, because the app relies
# only on "dependencies" at runtime (build tooling lives in devDependencies and
# is not needed on the server).
engine-strict=false
