# ===== FarmFreshFarmer environment =====
# Copy to `.env` for local development. On AWS Elastic Beanstalk, set these
# under Configuration > Software > Environment properties instead.

# ---- Core ----
NODE_ENV=development
# EB injects PORT automatically in production; 5000 is used locally.
PORT=5000

# ---- Database (PostgreSQL / AWS RDS) ----
# Local example:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/farmfreshfarmer
# AWS RDS example (uncomment & fill in):
# DATABASE_URL=postgres://USER:PASSWORD@your-db.xxxxxx.ap-south-1.rds.amazonaws.com:5432/farmfreshfarmer
# Force SSL (required by RDS). Auto-enabled for *.rds.amazonaws.com hosts.
PGSSL=false
PG_POOL_MAX=10

# ---- Session ----
# Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string
# Secure cookies require HTTPS. On Elastic Beanstalk behind an HTTPS listener,
# leave this unset (defaults to true in production). For local HTTP testing with
# NODE_ENV=production, set COOKIE_SECURE=false so the session cookie is sent.
# COOKIE_SECURE=true

# ---- PhonePe payment gateway (Standard Checkout v2 / OAuth) ----
# Get these from PhonePe Business dashboard > Developer Settings.
# You get SEPARATE credentials for sandbox (UAT) and production.
PHONEPE_ENV=sandbox                 # sandbox | production
PHONEPE_CLIENT_ID=YOUR_CLIENT_ID
PHONEPE_CLIENT_SECRET=YOUR_CLIENT_SECRET
PHONEPE_CLIENT_VERSION=1
# Merchant ID (shown bottom-left of the dashboard under your business name).
PHONEPE_MERCHANT_ID=YOUR_MERCHANT_ID
# Optional webhook Basic-Auth credentials you configure in the PhonePe dashboard
# (Developer Settings > Webhooks). PhonePe sends these in the Authorization header;
# we verify SHA256(username:password) against the incoming header.
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=
# Base URL of THIS app (used to build PhonePe redirect URL after payment).
# Local: http://localhost:5000  |  Production: https://your-domain.com
APP_BASE_URL=http://localhost:5000
# When PhonePe credentials are NOT set, the app can run a built-in payment
# simulator (a local success/fail page) so you can demo the full checkout flow.
# In development this is automatic. To enable it on a production-mode/staging
# deployment WITHOUT a live merchant account, set PHONEPE_ALLOW_SIMULATION=true.
# Leave it unset for a real production deployment so missing keys fail loudly.
# PHONEPE_ALLOW_SIMULATION=false
