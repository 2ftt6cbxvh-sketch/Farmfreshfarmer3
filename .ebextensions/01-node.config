# Elastic Beanstalk — Node.js platform configuration for FarmFreshFarmer
#
# The app is a single Express process that serves both the REST API and the
# built React client. It listens on process.env.PORT (EB injects PORT=8080 and
# proxies :80 -> :8080 via nginx). Production start is `npm start`
# (node dist/index.cjs) as declared in the Procfile.

option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
    # COOKIE_SECURE=true requires the environment to terminate HTTPS (ALB /
    # CloudFront with an ACM cert). If you have not enabled HTTPS yet, set this
    # to "false" temporarily so login cookies are still sent over http.
    COOKIE_SECURE: "true"
    # PHONEPE_ENV should be "production" once you have live PhonePe credentials.
    # Leave as "sandbox" while testing. Simulation is only allowed when PhonePe
    # is unconfigured AND PHONEPE_ALLOW_SIMULATION=true.
    PHONEPE_ENV: sandbox
    # Force TLS to RDS. The pg pool auto-detects *.rds.amazonaws.com and enables
    # SSL, but this makes intent explicit for non-RDS Postgres too.
    PGSSL: "true"
    # Install devDependencies too. The deploy migration/views commands run via
    # `npx tsx` (tsx is a devDependency). The app's own runtime only needs
    # "dependencies", but the one-time migration step needs tsx present.
    NPM_USE_PRODUCTION: "false"

  aws:elasticbeanstalk:container:nodejs:
    NodeCommand: "npm start"

  # nginx proxy is the EB default for the Node platform; the app must listen on
  # the PORT env var (it does). No extra proxy config needed.
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
