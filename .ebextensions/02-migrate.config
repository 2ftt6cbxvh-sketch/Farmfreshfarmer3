# Run database migrations + reporting views on every deploy, once per
# deployment (not once per instance), BEFORE the new app version goes live.
#
# `container_commands` run from the app staging directory after the app is
# unpacked but before it is deployed to the running location. `leader_only`
# ensures the command runs on a single instance only (safe for RDS).
#
# These use `npx tsx` because the migrate/seed/views scripts are TypeScript.
# `tsx` is a devDependency; EB installs all dependencies by default, so it is
# available. DATABASE_URL comes from the environment properties you set on the
# EB environment (pointing at your RDS Postgres instance).

# The application itself seeds settings / default admin / sample catalog on
# every boot (idempotent), so we do NOT need a seed container command here.
# We only need to ensure the SCHEMA exists (migrations) and the reporting
# views are up to date before the new version goes live.

container_commands:
  01_migrate:
    command: "npx tsx script/migrate.ts"
    leader_only: true
  02_views:
    command: "npx tsx script/apply-views.ts"
    leader_only: true
