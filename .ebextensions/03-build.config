# Build the production bundle ON the EB instance, from source, after
# dependencies are installed and before the app starts.
#
# Why build on-server instead of trusting the dist/ in the ZIP?
#   - Guarantees the client + server bundle match the source in the ZIP.
#   - Avoids shipping a stale dist/.
#   - The build step (vite + esbuild + tsx) uses devDependencies, which are
#     installed because NPM_USE_PRODUCTION=false (see 01-node.config).
#
# `container_commands` run from the staging dir after npm install and before
# the app is promoted to the running location. This one is NOT leader_only —
# every instance needs its own built dist/ to run `node dist/index.cjs`.

container_commands:
  00_build:
    command: "npm run build"
